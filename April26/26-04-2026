from typing import List

class Solution:
    def containsCycle(self, grid: List[List[str]]) -> bool:
        if not grid or not grid[0]:
            return False
        
        m, n = len(grid), len(grid[0])
        visited = [[False] * n for _ in range(m)]
        
        def dfs(row: int, col: int, parent_row: int, parent_col: int, char: str) -> bool:
            # Mark current cell as visited
            visited[row][col] = True
            
            # Check all 4 directions
            directions = [(0, 1), (1, 0), (0, -1), (-1, 0)]
            
            for dr, dc in directions:
                new_row, new_col = row + dr, col + dc
                
                # Check if the new cell is within bounds and has the same character
                if 0 <= new_row < m and 0 <= new_col < n and grid[new_row][new_col] == char:
                    # If we haven't visited this cell, explore it
                    if not visited[new_row][new_col]:
                        if dfs(new_row, new_col, row, col, char):
                            return True
                    # If we've visited this cell and it's not our parent, we found a cycle
                    elif new_row != parent_row or new_col != parent_col:
                        return True
            
            return False
        
        # Check each unvisited cell for cycles
        for i in range(m):
            for j in range(n):
                if not visited[i][j]:
                    if dfs(i, j, -1, -1, grid[i][j]):
                        return True
        
        return False
