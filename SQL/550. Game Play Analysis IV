WITH first_logins AS (
    SELECT player_id, MIN(event_date) AS first_date
    FROM Activity
    GROUP BY player_id
)
SELECT ROUND(
    COUNT(*)::DECIMAL / (SELECT COUNT(*) FROM first_logins),
    2
) AS fraction
FROM first_logins f
WHERE EXISTS (
    SELECT 1
    FROM Activity a
    WHERE a.player_id = f.player_id
      AND a.event_date = f.first_date + INTERVAL '1 day'
);
