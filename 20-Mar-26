#3567. Minimum Absolute Difference in Sliding Submatrix

class Solution:
    def minAbsDiff(self, grid: List[List[int]], k: int) -> List[List[int]]:
        m, n = len(grid), len(grid[0])
        result = [[0] * (n - k + 1) for _ in range(m - k + 1)]
        
        for i in range(m - k + 1):
            for j in range(n - k + 1):
                # Extract all values from the k×k submatrix
                values = set()  # Use a set to store distinct values
                for x in range(i, i + k):
                    for y in range(j, j + k):
                        values.add(grid[x][y])
                
                # Convert to sorted list
                sorted_values = sorted(values)
                
                # If there's only one distinct value, answer is 0
                if len(sorted_values) == 1:
                    result[i][j] = 0
                    continue
                
                # Find minimum absolute difference between consecutive distinct values
                min_diff = float('inf')
                for idx in range(1, len(sorted_values)):
                    diff = abs(sorted_values[idx] - sorted_values[idx-1])
                    if diff < min_diff:
                        min_diff = diff
                
                result[i][j] = min_diff
        
        return result
