import java.util.*;

class Solution {
    public int maximumLength(int[] nums) {
        Map<Long, Integer> freq = new HashMap<>();
        for (int num : nums) {
            freq.merge((long) num, 1, Integer::sum);
        }

        int ans = 1;

        // Special case: all values are 1, so we can only use an odd number of them.
        int ones = freq.getOrDefault(1L, 0);
        if (ones > 0) {
            int maxOdd = (ones % 2 == 1) ? ones : ones - 1;
            ans = Math.max(ans, maxOdd);
        }

        long LIMIT = 1_000_000_000L;

        for (long x : freq.keySet()) {
            if (x == 1) continue;

            int len = 1;
            long cur = x;

            while (true) {
                // To extend one more level, current middle value must appear at least twice.
                if (freq.getOrDefault(cur, 0) < 2) break;

                long next = cur * cur;
                if (next > LIMIT || !freq.containsKey(next)) break;

                len += 2;
                cur = next;
            }

            ans = Math.max(ans, len);
        }

        return ans;
    }
}