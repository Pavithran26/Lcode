from collections import deque
from typing import List

class Solution:
    def minJumps(self, arr: List[int]) -> int:
        n = len(arr)
        if n == 1:
            return 0
        
        # Map each value to the list of indices where it appears
        value_to_indices = {}
        for i, val in enumerate(arr):
            if val not in value_to_indices:
                value_to_indices[val] = []
            value_to_indices[val].append(i)
        
        visited = set()
        visited.add(0)
        q = deque()
        q.append((0, 0))  # (index, steps)
        
        while q:
            idx, steps = q.popleft()
            if idx == n - 1:
                return steps
            
            # Same value jumps (teleportation)
            if arr[idx] in value_to_indices:
                for nxt in value_to_indices[arr[idx]]:
                    if nxt not in visited:
                        visited.add(nxt)
                        q.append((nxt, steps + 1))
                # Clear to avoid reprocessing this value again
                value_to_indices[arr[idx]] = []
            
            # Neighbors: i-1 and i+1
            for nxt in (idx - 1, idx + 1):
                if 0 <= nxt < n and nxt not in visited:
                    visited.add(nxt)
                    q.append((nxt, steps + 1))
        
        # Should never reach here for valid input
        return -1
