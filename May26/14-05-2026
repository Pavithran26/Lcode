from typing import List
from collections import Counter

class Solution:
    def isGood(self, nums: List[int]) -> bool:
        n = max(nums)
        # Length must be n + 1
        if len(nums) != n + 1:
            return False
        
        # Count frequencies
        freq = Counter(nums)
        
        # Check numbers 1..n-1 appear exactly once
        for i in range(1, n):
            if freq.get(i, 0) != 1:
                return False
        
        # Check n appears exactly twice
        return freq.get(n, 0) == 2
