from typing import List

class Solution:
    def maxRotateFunction(self, nums: List[int]) -> int:
        n = len(nums)
        if n == 1:
            return 0
            
        # Calculate sum of all elements
        total_sum = sum(nums)
        
        # Calculate F(0)
        f0 = 0
        for i in range(n):
            f0 += i * nums[i]
        
        # Calculate all F(k) using recurrence relation
        max_f = f0
        fk = f0
        
        for k in range(1, n):
            # The element that moves from position n-k to position 0 is nums[n-k]
            fk = fk + total_sum - n * nums[n - k]
            max_f = max(max_f, fk)
        
        return max_f
