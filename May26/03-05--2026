class Solution:
    def rotateString(self, s: str, goal: str) -> bool:
        # If lengths are different, impossible to be rotation
        if len(s) != len(goal):
            return False
        
        # If s and goal are equal, that's valid (0 shifts)
        if s == goal:
            return True
        
        # For strings of same length, check if goal is substring of s+s
        # This works because any rotation of s appears as a contiguous substring in s+s
        return goal in s + s
